# Hermes Discord Bot Configuration
# Copy to .env and fill in your values

# REQUIRED - Get from Discord Developer Portal
DISCORD_BOT_TOKEN=your_bot_token_here
# Hermes Gateway connection (default: localhost:8642)
HERMES_GATEWAY_URL=http://localhost:8642

# Logging
LOG_LEVEL=INFO

# Optional: Slash command sync behavior
# CLEAR_GLOBAL_COMMANDS=false  # Set true to clear global commands on startup