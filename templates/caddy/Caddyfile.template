# {{DOMAIN}} — Caddy Reverse Proxy
# Rendered from templates/caddy/Caddyfile.template
# Installs to: /etc/caddy/Caddyfile
# Cloudflare handles SSL (Full/Strict), Caddy runs HTTP only

{
    admin off
    http_port 80
    https_port 443
}

# Gateway API
{{SUBDOMAIN_GATEWAY}}.{{DOMAIN}} {
    reverse_proxy 127.0.0.1:{{GW_PORT}} {
        transport http {
            read_buffer 4096
        }
    }
    header {
        X-Forwarded-Proto "https"
        X-Real-IP {remote_host}
        X-Forwarded-For {remote_host}
    }
}

# Workspace Dashboard
{{SUBDOMAIN_WORKSPACE}}.{{DOMAIN}} {
    reverse_proxy 127.0.0.1:{{WS_PORT}} {
        transport http {
            read_buffer 4096
        }
    }
    header {
