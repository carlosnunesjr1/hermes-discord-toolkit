# Terminal (ttyd)
{{SUBDOMAIN_TERMINAL}}.{{DOMAIN}} {
    reverse_proxy 127.0.0.1:{{TERMINAL_PORT}} {
        transport http {
            read_buffer 4096
        }
    }
    # WebSocket support for ttyd
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websocket {
        reverse_proxy 127.0.0.1:{{TERMINAL_PORT}} {
            transport http {
                read_buffer 4096
            }
        }
    }
}

