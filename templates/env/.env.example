# ==========================================
# HERMES DISCORD TOOLKIT — CONFIGURATION
# Copy to ~/.config/hermes-discord-toolkit/.env.local and fill in
# ==========================================

# Discord Bot (required)
DISCORD_BOT_TOKEN={{DISCORD_BOT_TOKEN}}
DISCORD_ALLOWED_USERS={{DISCORD_ALLOWED_USERS}}
DISCORD_HOME_CHANNEL={{DISCORD_HOME_CHANNEL}}
DISCORD_HOME_CHANNEL_THREAD_ID={{DISCORD_HOME_CHANNEL_THREAD_ID}}

# Domain & SSL (Cloudflare + Caddy)
DOMAIN={{DOMAIN}}                           # e.g. example.com
SUBDOMAIN_GATEWAY=gateway                   # gateway.{{DOMAIN}}
SUBDOMAIN_WORKSPACE=workspace               # workspace.{{DOMAIN}}
SUBDOMAIN_CAREER=career                     # career.{{DOMAIN}}
SUBDOMAIN_PIM=pim                           # pim.{{DOMAIN}}
SUBDOMAIN_TERMINAL=terminal                 # terminal.{{DOMAIN}}
SUBDOMAIN_CENTRAL=centraldecomando          # centraldecomando.{{DOMAIN}}
SUBDOMAIN_CONTROL=control-daemon            # control-daemon.{{DOMAIN}}
SUBDOMAIN_NEXUS=nexus-pim                   # nexus-pim.{{DOMAIN}}

# Ports (Hermes defaults)
GW_PORT={{GW_PORT:-8642}}
WS_PORT={{WS_PORT:-3002}}
DASH_PORT={{DASH_PORT:-9119}}
CAREER_PORT={{CAREER_PORT:-2019}}
PIM_PORT={{PIM_PORT:-9121}}
TERMINAL_PORT={{TERMINAL_PORT:-7681}}
CENTRAL_PORT={{CENTRAL_PORT:-9130}}
CONTROL_PORT={{CONTROL_PORT:-9120}}
NEXUS_PORT={{NEXUS_PORT:-9121}}

# API Server (gateway)
API_SERVER_ENABLED=true
API_SERVER_KEY={{API_SERVER_KEY}}           # generate: openssl rand -hex 32
API_SERVER_PORT={{GW_PORT}}
API_SERVER_HOST=127.0.0.1
API_SERVER_MODEL_NAME=hermes-agent

# Webhook (optional)
WEBHOOK_ENABLED={{WEBHOOK_ENABLED:-true}}
WEBHOOK_PORT={{WEBHOOK_PORT:-8644}}
WEBHOOK_SECRET={{WEBHOOK_SECRET}}           # generate: openssl rand -hex 32

# STT/TTS (optional)
STT_ENABLED={{STT_ENABLED:-true}}
STT_PROVIDER={{STT_PROVIDER:-local}}
TTS_PROVIDER={{TTS_PROVIDER:-edge}}

# Gateway
GATEWAY_ALLOW_ALL_USERS={{GATEWAY_ALLOW_ALL_USERS:-false}}

# Optional: Headroom (context compression)
HEADROOM_ENABLED={{HEADROOM_ENABLED:-false}}
HEADROOM_URL={{HEADROOM_URL:-http://127.0.0.1:8799}}